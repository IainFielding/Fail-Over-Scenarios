<mxfile host="app.diagrams.net">
  <diagram name="10-decision-flowchart" id="10-decision-flowchart">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1160" pageHeight="940" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t" value="PaaS resilience decision flow - which tier?" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="0" y="10" width="1000" height="30" as="geometry"/></mxCell>
        <mxCell id="start" value="Start: pick a PaaS resilience tier" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="60" width="200" height="46" as="geometry"/></mxCell>
        <mxCell id="qprov" value="Must survive a whole cloud-provider outage?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1"><mxGeometry x="80" y="135" width="200" height="95" as="geometry"/></mxCell>
        <mxCell id="qreg" value="Must survive a full-region outage?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1"><mxGeometry x="80" y="270" width="200" height="95" as="geometry"/></mxCell>
        <mxCell id="qzone" value="Need ~99.99% (survive a zone outage)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1"><mxGeometry x="80" y="430" width="200" height="95" as="geometry"/></mxCell>
        <mxCell id="qlocal" value="Need automatic local HA / no data loss?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1"><mxGeometry x="80" y="590" width="200" height="95" as="geometry"/></mxCell>
        <mxCell id="qaa" value="Zero-downtime active/active (multi-writer OK)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1"><mxGeometry x="560" y="250" width="210" height="95" as="geometry"/></mxCell>
        <mxCell id="qread" value="Is read-only global resilience enough?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1"><mxGeometry x="560" y="380" width="210" height="95" as="geometry"/></mxCell>
        <mxCell id="qauto" value="Automatic managed failover (vs cheapest cutover)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1"><mxGeometry x="560" y="505" width="210" height="95" as="geometry"/></mxCell>
        <mxCell id="out9" value="#9 Multi-cloud PaaS&#10;(parity is the hard part)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="320" y="150" width="230" height="60" as="geometry"/></mxCell>
        <mxCell id="out3" value="#3 Zone-redundant&#10;(the 99.99% checkbox)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="320" y="445" width="230" height="60" as="geometry"/></mxCell>
        <mxCell id="out2" value="#2 Local HA&#10;(managed multi-instance)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="320" y="605" width="230" height="60" as="geometry"/></mxCell>
        <mxCell id="out1" value="#1 Single region&#10;+ automatic PITR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="750" width="200" height="56" as="geometry"/></mxCell>
        <mxCell id="out7" value="#7 Active/active + global managed DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="820" y="265" width="230" height="56" as="geometry"/></mxCell>
        <mxCell id="out6" value="#6 Global read replicas (single-writer)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="820" y="395" width="230" height="56" as="geometry"/></mxCell>
        <mxCell id="out5" value="#5 Managed regional failover group" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="820" y="485" width="230" height="52" as="geometry"/></mxCell>
        <mxCell id="out4" value="#4 Serverless scale-to-zero pilot light" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="820" y="560" width="230" height="52" as="geometry"/></mxCell>
        <mxCell id="ep1" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#888888;endArrow=block;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="qprov" target="qreg"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ep2" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82B366;endArrow=block;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="qprov" target="out9"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="er1" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#888888;endArrow=block;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="qreg" target="qzone"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="er2" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82B366;endArrow=block;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="qreg" target="qaa"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ez1" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#888888;endArrow=block;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="qzone" target="qlocal"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ez2" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82B366;endArrow=block;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="qzone" target="out3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="el1" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#888888;endArrow=block;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="qlocal" target="out1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="el2" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82B366;endArrow=block;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="qlocal" target="out2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea1" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#888888;endArrow=block;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="qaa" target="qread"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea2" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82B366;endArrow=block;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="qaa" target="out7"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="erd1" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#888888;endArrow=block;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="qread" target="qauto"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="erd2" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82B366;endArrow=block;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="qread" target="out6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="eau1" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82B366;endArrow=block;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="qauto" target="out5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="eau2" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#888888;endArrow=block;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="qauto" target="out4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="overlay" value="Multi-tenant SaaS?  Overlay #8 Cell-based / deployment stamps on ANY tier above to bound the blast radius of a bad deploy, hot tenant, or poison-pill request." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="80" y="850" width="970" height="50" as="geometry"/></mxCell>
        <mxCell id="heat" value="Outcome colour = resilience:  red = least  -&gt;  orange  -&gt;  yellow  -&gt;  green = most" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="560" y="700" width="490" height="20" as="geometry"/></mxCell>
