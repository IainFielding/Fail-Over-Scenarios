        <mxCell id="note" value="Each cell is an independent full PaaS stack serving a fixed tenant slice; a bad deploy, hot tenant, or poison-pill request is contained to one cell.&lt;br&gt;An overlay - combine with zone/region redundancy (scenarios 3-7). Serverless makes many small cells cheap." style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="120" y="585" width="820" height="40" as="geometry"/></mxCell>
