        <mxCell id="c1" value="Choosing a 3-tier resilience topology - decision flow" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="0" y="0" width="1700" height="30" as="geometry"/></mxCell>
