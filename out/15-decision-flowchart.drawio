  <diagram name="15-decision-flowchart" id="15-decision-flowchart">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="c1" value="Choosing a 3-tier resilience topology - decision flow" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="0" y="0" width="1900" height="30" as="geometry"/></mxCell>
        <mxCell id="c2" value="Start" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;arcSize=40;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="50" y="360" width="150" height="50" as="geometry"/></mxCell>
        <mxCell id="c3" value="Survive an entire&lt;br&gt;cloud-provider outage?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="320" y="350" width="200" height="110" as="geometry"/></mxCell>
        <mxCell id="c4" value="Survive a full&lt;br&gt;region outage?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="590" y="150" width="200" height="110" as="geometry"/></mxCell>
        <mxCell id="c5" value="Need continuous service,&lt;br&gt;no failover (active/active)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="590" y="620" width="200" height="110" as="geometry"/></mxCell>
        <mxCell id="c6" value="Need automatic recovery&lt;br&gt;from instance / zone failure?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="860" y="60" width="200" height="110" as="geometry"/></mxCell>
        <mxCell id="c7" value="Need zero-downtime regional&lt;br&gt;failover (active/active)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="860" y="300" width="200" height="110" as="geometry"/></mxCell>
        <mxCell id="c8" value="More than one&lt;br&gt;region per cloud?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="860" y="760" width="200" height="110" as="geometry"/></mxCell>
